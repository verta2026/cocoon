<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/card_bg">

    <TextView
        android:id="@+id/tasks_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#7A6552"
        android:text="@string/widget_tasks" />

    <LinearLayout android:id="@+id/task_row0" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingTop="6dp" android:gravity="center_vertical">
        <ImageView android:id="@+id/task_box0" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/checkbox_empty" android:contentDescription="@null" />
        <TextView android:id="@+id/task_text0" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textSize="14sp" android:textColor="#4A382A" android:maxLines="1" android:ellipsize="end" />
    </LinearLayout>
    <LinearLayout android:id="@+id/task_row1" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingTop="6dp" android:gravity="center_vertical">
        <ImageView android:id="@+id/task_box1" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/checkbox_empty" android:contentDescription="@null" />
        <TextView android:id="@+id/task_text1" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textSize="14sp" android:textColor="#4A382A" android:maxLines="1" android:ellipsize="end" />
    </LinearLayout>
    <LinearLayout android:id="@+id/task_row2" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingTop="6dp" android:gravity="center_vertical">
        <ImageView android:id="@+id/task_box2" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/checkbox_empty" android:contentDescription="@null" />
        <TextView android:id="@+id/task_text2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textSize="14sp" android:textColor="#4A382A" android:maxLines="1" android:ellipsize="end" />
    </LinearLayout>
    <LinearLayout android:id="@+id/task_row3" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingTop="6dp" android:gravity="center_vertical">
        <ImageView android:id="@+id/task_box3" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/checkbox_empty" android:contentDescription="@null" />
        <TextView android:id="@+id/task_text3" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textSize="14sp" android:textColor="#4A382A" android:maxLines="1" android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
